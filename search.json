---
layout: null
sitemap: false
---
[
{% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": "{{ post.date | date: '%Y-%m-%d' }}",
    "summary": {{ post.summary | default: post.excerpt | strip_html | normalize_whitespace | jsonify }},
    "content": {{ post.content | strip_html | normalize_whitespace | truncate: 500 | jsonify }},
    "lang": {{ post.lang | default: 'zh' | jsonify }},
    "categories": [{% for category in post.categories %}{{ category | jsonify }}{% unless forloop.last %},{% endunless %}{% endfor %}],
    "tags": [{% for tag in post.tags %}{{ tag | jsonify }}{% unless forloop.last %},{% endunless %}{% endfor %}]
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
